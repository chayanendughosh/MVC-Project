@* Design: Corporate & Professional Blue — Poppins *@
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
<style>
    *, *::before, *::after {
        box-sizing: border-box;
    }

    body {
        font-family: 'Poppins', sans-serif !important;
        background: #f0f4f9;
        color: #1a2b4a;
        margin: 0;
        padding: 24px 32px;
    }

    h2 {
        font-size: 26px;
        font-weight: 700;
        color: #0a2e6e !important;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        border-left: 5px solid #1565c0;
        padding-left: 14px;
        margin: 0 0 24px;
    }

    #formErrors {
        color: #b91c1c;
        font-size: 13px;
        margin-bottom: 12px;
    }

    div > form, div > div {
        background: #fff;
        border-top: 4px solid #1565c0;
        border: 1px solid #d0d9e8;
        border-top: 4px solid #1565c0;
        border-radius: 0 0 4px 4px;
        padding: 32px 36px;
        max-width: 620px;
    }

    form p {
        margin: 0 0 18px;
        display: flex;
        flex-direction: column;
        gap: 5px;
    }

    form label {
        font-size: 12px;
        font-weight: 600;
        color: #0a2e6e !important;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    form input[type="text"],
    form input[type="email"],
    form input[type="number"],
    form textarea,
    form select {
        width: 100%;
        padding: 9px 12px;
        border: 1px solid #c4d2e8;
        border-radius: 3px;
        font-family: 'Poppins', sans-serif;
        font-size: 14px;
        color: #1a2b4a;
        background: #f8fafd;
        transition: border-color 0.2s;
        outline: none;
    }

        form input[type="text"]:focus,
        form input[type="email"]:focus,
        form textarea:focus,
        form select:focus {
            border-color: #1565c0;
            background: #fff;
            box-shadow: 0 0 0 3px rgba(21,101,192,0.1);
        }

        form select[multiple] {
            height: auto;
            min-height: 110px;
        }

    form input[type="radio"] {
        margin-right: 5px;
    }

    form button[type="submit"] {
        background: #1565c0;
        color: #fff;
        border: none;
        border-radius: 3px;
        padding: 10px 28px;
        font-family: 'Poppins', sans-serif;
        font-size: 13px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        cursor: pointer;
        transition: background 0.2s;
        margin-right: 12px;
    }

        form button[type="submit"]:hover {
            background: #0d47a1;
        }

    form a[href*="Index"] {
        color: #1565c0 !important;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        border-bottom: 1px solid #b3c9e8;
        padding-bottom: 1px;
    }

        form a[href*="Index"]:hover {
            color: #0d47a1 !important;
        }
</style>

@model WebApplication1.Models.UserViewModel

@{
    ViewBag.Title = "Create User";
}

<h2>Create User</h2>

<div id="formErrors"></div>

<div>
    @using (Html.BeginForm("Create", "Users", FormMethod.Post, new { id = "userForm" }))
    {
        @Html.AntiForgeryToken()
        <p>
            @Html.LabelFor(m => m.Name)
            @Html.TextBoxFor(m => m.Name)
        </p>
        <p>
            @Html.LabelFor(m => m.Email)
            @Html.TextBoxFor(m => m.Email)
        </p>
        <p>
            @Html.LabelFor(m => m.Mobile)
            @Html.TextBoxFor(m => m.Mobile)
        </p>
        <p>
            @Html.LabelFor(m => m.Address)
            @Html.TextAreaFor(m => m.Address, new { rows = 3 })
        </p>
        <p>
            <label>Gender</label><br />
            @Html.RadioButtonFor(m => m.Gender, "Male") Male
            @Html.RadioButtonFor(m => m.Gender, "Female") Female
        </p>
        <p>
            @Html.LabelFor(m => m.StateId, "State")
            @Html.TextBox("stateAuto", null, new { autocomplete = "off" })
            @Html.HiddenFor(m => m.StateId)
        </p>
        <p>
            <label>Hobbies (Select multiple)</label><br />
            @Html.ListBoxFor(m => m.SelectedHobbies, Model.AvailableHobbies, new { size = 5 })
        </p>

        <p>
            <button type="submit">Save</button>
            <a href="@Url.Action("Index", "Users")">Back</a>
        </p>
    }
</div>

@section scripts{
    <script>
        $(function(){
            // autocomplete for states
            $('#stateAuto').autocomplete({
                source: '@Url.Action("States")',
                minLength: 1,
                select: function(event, ui){
                    $('#StateId').val(ui.item.id);
                }
            });

            $('#userForm').submit(function(e){
                e.preventDefault();
                var data = $(this).serialize();

                $.ajax({
                    url: this.action,
                    method: this.method,
                    data: data,
                    success: function(res){
                        if(res.success){
                            alert('Saved successfully');
                            window.location = '@Url.Action("Index", "Users")';
                        } else {
                            alert('Error');
                        }
                    },
                    error: function(xhr){
                        var resp = xhr.responseJSON;
                        if(resp && resp.errors){
                            alert(resp.errors.join('\n'));
                        } else alert('Unexpected error');
                    }
                });
            });
        });
    </script>
}
